# Copy this file to .env and fill in real values locally.
# .env is gitignored and should never be committed.
# In GitHub Actions, these are set as repository variables/secrets instead
# (see docs/07-github-actions-logic.md).

# --- Source URLs (non-secret, but kept here for local convenience) ---
CARDMARKET_PRICE_GUIDE_URL=
CARDMARKET_PRODUCTS_SINGLES_URL=
CARDMARKET_PRODUCTS_NONSINGLES_URL=

# --- Raw archive (FTP / object storage) ---
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_REMOTE_dir=

# --- Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database (Postgres via Supabase, free tier) ---
# Two separate Supabase projects: dev and prod (see docs/04-etl-pipeline-design.md).
# In YOUR LOCAL .env, DATABASE_URL should point at the DEV project — safe to
# break, reset, or reload at any time. The GitHub Actions secret of the same
# name points at PROD instead. Same variable name, two different values,
# never mixed up in the same place.
# Use the POOLED connection string (Supavisor, transaction mode), not the
# direct connection — short-lived pipeline runs should not hold direct
# connections open. Use a database-role/service credential, not the
# anon/public client key.
DATABASE_URL=

# Session Pooler connection string (different from DATABASE_URL above) for
# whichever project you're backing up — normally PROD. pg_dump needs full
# session semantics that the transaction pooler doesn't support. Only
# needed locally when running a manual backup, or as a GitHub Actions
# secret if backup-database.yml is implemented. See docs/04, "Backing up
# the prod project."
DATABASE_URL_BACKUP=

# --- Pipeline behavior ---
# Every date-based rule in this project (snapshotDate, catalog archive date)
# is anchored to Europe/Vienna, regardless of where the pipeline runs.
PIPELINE_TIMEZONE=Europe/Vienna
